# ClickHouse 连接配置
CH_HOST=10.100.0.205
CH_PORT=18123
CH_USER=reader
CH_PASSWORD=
CH_DATABASE=quant_db

# DuckDB 路径（项目本地缓存）
DUCKDB_PATH=./factor_data/cache/quant_cache.duckdb

# Qlib 数据目录
QLIB_DATA_DIR=./qlib_data

# 特征选择缓存目录
FS_CACHE_DIR=./factor_data/cache

# 因子仓库目录（Parquet 文件 + meta.json）
WAREHOUSE_DIR=./factor_data/warehouse

# Tushare Token（数据后备源）
TUSHARE_TOKEN=your_tushare_token_here

# 交易费率
STAMP_DUTY=0.0005
COMMISSION=0.0003

# Python 虚拟环境（Conda）
CONDA_ENV_NAME=Quant
CONDA_ENV_PATH=E:\Program Files\Anaconda\envs\Quant
CONDA_PYTHON_EXE=E:\Program Files\Anaconda\envs\Quant\python.exe