# ==================== ClickHouse 连接配置 ====================
# 使用 reader 用户进行只读查询
CH_HOST=10.100.0.205
CH_PORT=18123
CH_USER=reader
CH_PASSWORD=
CH_DATABASE=quant_db

# ==================== DuckDB 路径 ====================
# 项目目录下的缓存数据库，便于统一管理
DUCKDB_PATH=./data/cache/quant_cache.duckdb

# ==================== Qlib 数据目录 ====================
QLIB_DATA_DIR=./qlib_data

# ==================== 特征选择缓存目录 ====================
FS_CACHE_DIR=./.fs_cache

# ==================== 数据规范配置 ====================
# 强制使用前复权价格（不复权数据会导致因子失效）
# 量化标准：前复权确保价格连续性和可比性
FORCE_ADJUSTED_PRICES=true

# 财报数据使用公告日期（ann_date），而非期末日期（end_date）
# 公告日期是数据正式发布日期，更适合量化因子计算
FINANCIAL_USE_ANNOUNCEMENT_DATE=true

# 价格复权类型：qfq=前复权, hfq=后复权, None=不复权
ADJUSTED_PRICE_TYPE=qfq

# ==================== 其他配置 ====================
# 缓存过期时间（秒），默认 24 小时
CACHE_TTL=86400
